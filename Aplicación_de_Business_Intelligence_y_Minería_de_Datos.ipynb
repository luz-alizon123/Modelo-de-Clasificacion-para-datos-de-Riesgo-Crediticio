    {
      "cell_type": "markdown",
      "source": [
        "Calcula el percentil 99 de la columna \"edad\", lo que significa que el 99% de las edades en estos datos son menores o iguales a 50 años. Lo que significa que el promedio de edad de los prestamistas es de 50 años."
      ],
      "metadata": {
        "id": "7uQjxvcANgXy"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "**CáLCULO DE OUTLIERS CON IQR**"
      ],
      "metadata": {
        "id": "lsMQPrrlNkFS"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def outliers_iqr(d, L):\n",
        "    dd = d.copy()\n",
        "    data = d[L].copy()\n",
        "    iqr = data.quantile(0.75) - data.quantile(0.25)\n",
        "    sup = data.quantile(0.75) + 1.5 * iqr\n",
        "    inf = data.quantile(0.25) - 1.5 * iqr\n",
        "    data.loc[:, \"flag\"] = False\n",
        "    for i in L:\n",
        "        data.loc[:, \"flag\"] = (data[\"flag\"]) | (data[i] > sup[i]) | (data[i] < inf[i])\n",
        "    dd.loc[:, \"flag\"] = data[\"flag\"]\n",
        "    # Calculo de porcentaje de outliers\n",
        "    outliers_pct = np.round(100 * data[\"flag\"].sum() / len(data), 2)\n",
        "    print(f\"Existe {outliers_pct}% de outliers\")\n",
        "    return dd"
      ],
      "metadata": {
        "id": "UAUEdvChNia6"
      },
      "execution_count": 37,
      "outputs": []
    },
