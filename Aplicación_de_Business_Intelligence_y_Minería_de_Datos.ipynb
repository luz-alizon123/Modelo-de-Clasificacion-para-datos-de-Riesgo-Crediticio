    {
      "cell_type": "code",
      "source": [
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "# Primera división: 70% entrenamiento, 30% temporal (para validación y prueba)\n",
        "X_temp, X_test, y_temp, y_test = train_test_split(\n",
        "    X, Y, test_size=0.3, random_state=42, stratify=Y\n",
        ")\n",
        "\n",
        "# Segunda división: de ese 30% temporal, se divide en 50/50 → 15% validación y 15% prueba\n",
        "X_train, X_val, y_train, y_val = train_test_split(\n",
        "    X_temp, y_temp, test_size=0.2143, random_state=42, stratify=y_temp\n",
        ")\n",
        "\n",
        "print(\"Tamaño de X_train:\", X_train.shape)\n",
        "print(\"Tamaño de X_val:\", X_val.shape)\n",
        "print(\"Tamaño de X_test:\", X_test.shape)"
      ],
      "metadata": {
        "id": "2qMR0SOmROxJ",
        "colab": {
          "base_uri": "https://localhost:8080/"
