    {
      "cell_type": "code",
      "source": [
        "from scipy import linalg"
      ],
      "metadata": {
        "id": "2DOhEEweNuSj"
      },
      "execution_count": 39,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Selección de variables\n",
        "x = d[[\"edad\", \"ingreso\", \"experiencia\", \"monto\", \"tasa\", \"monto/sueldo\", \"historial\"]]\n",
        "\n",
        "# Matriz de covarianza e inversa (sin estandarizar)\n",
        "Sx = x.cov().values\n",
        "Sx_inv = sp.linalg.inv(Sx)\n",
        "\n",
        "# Vector de medias\n",
        "mean = x.mean().values\n",
        "\n",
        "# Función Mahalanobis\n",
        "def mahalanobisR(x, meanCol, IC):\n",
        "    return [mahalanobis(x.iloc[i,:], meanCol, IC)**2 for i in range(x.shape[0])]\n",
        "\n",
        "# Cálculo y almacenamiento\n",
        "d[\"mR\"] = mahalanobisR(x, mean, Sx_inv)\n",
        "\n",
        "# Detección de outliers\n",
        "from scipy.stats import chi2\n",
        "umbral = chi2.ppf(0.99, df=x.shape[1])  # con el 99% de confianza\n",
        "d[\"outlier_mahal\"] = d[\"mR\"] > umbral\n",
        "\n",
        "# Gráfico\n",
        "plt.figure(figsize=(10,5))\n",
        "d[\"mR\"].plot(title=\"Distancias de Mahalanobis\")\n",
        "plt.axhline(umbral, color='red', linestyle='--', label='Umbral chi² (99%)')\n",
        "plt.legend()\n",
        "plt.show()"
      ],
      "metadata": {
        "id": "LCJf7xeGN0CU",
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 676
        },
        "outputId": "3f7c4097-d618-42bf-acf1-7c7f28aa0efd"
